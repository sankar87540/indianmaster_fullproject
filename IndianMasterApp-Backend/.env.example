# Application Environment Configuration

# App Environment (development, staging, production)
APP_ENV=development
ENVIRONMENT=development

# Server Configuration
APP_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=indian_master
DB_SSLMODE=disable

# JWT Secret — must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-in-production

# CORS — comma-separated list of allowed browser origins (admin web, etc.)
# Leave empty to allow all origins in development. Must be set in production.
# Example: CORS_ALLOWED_ORIGINS=https://admin.indianmaster.com,https://app.indianmaster.com
CORS_ALLOWED_ORIGINS=

# Redis Configuration
REDIS_URL=localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Gin Mode (debug, release, test)
GIN_MODE=release
